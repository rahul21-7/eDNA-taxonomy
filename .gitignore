profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1255, pipenv should generally check in Pipfile.lock.
#   However, if you're developing a system tool, you can yolo it and remove it.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock should be checked in depending on developer preference.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock should be checked in depending on developer preference.
# pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
ENV/local/
ENV/lib/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site/

